# ---------- 服务 ----------
PORT=3000

# ---------- 数据库 ----------
# sqlite（本地文件）或 mysql
DB_TYPE=mysql

# —— SQLite（仅 DB_TYPE=sqlite）——
# DATABASE_PATH=data/matrix.db

# —— MySQL（DB_TYPE=mysql）——
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=matrix_data
DB_CHARSET=utf8mb4
# 启动时会自动 CREATE DATABASE IF NOT EXISTS（库名仅字母数字下划线）
# DB_POOL_SIZE=10

# 每日 23:59 归档抖音统计使用的时区（与定时任务一致）
# SNAPSHOT_TZ=Asia/Shanghai

# 管理员账号（ADMIN_USERNAME）登录后，可在前端「账号数据」里手动写入每日归档，无需仅依赖本处变量。
#
# —— 归档 / 对比调试（仅开发环境建议开启；开启后下列变量才会生效）——
# SNAPSHOT_DEBUG=1
# 与「昨天」对比时改用指定归档日（YYYY-MM-DD），并参与卡片增量计算
# SNAPSHOT_DEBUG_BASELINE_YMD=2026-04-19
# 与上面对比日合并的字段（可补全库中缺失，或覆盖库值）。示例：
# SNAPSHOT_DEBUG_BASELINE_JSON={"likes":100,"mutual":0,"following":50,"followers":1000,"parsed":true}
# 按日期覆盖「账号数据」里点某一天看到的落库内容（JSON 键为日期）。示例：
# SNAPSHOT_DEBUG_VIEW_OVERRIDES={"2026-04-19":{"likes":999,"parsed":true}}

# ---------- 认证 ----------
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

REGISTER_ENABLED=true

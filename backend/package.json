{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "bundle:bin": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=build/index.cjs --packages=external",
    "build:binary:linux": "npm run bundle:bin && pkg build/index.cjs --target node18-linux-x64 --output bin/matrix-api",
    "playwright:install": "playwright install chromium",
    "snapshot:once": "tsx src/cli/runSnapshotOnce.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.1",
    "node-cron": "^4.2.1",
    "playwright": "^1.51.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.25.11",
    "pkg": "^5.8.1",
    "tsx": "^4.19.3",
    "typescript": "~5.8.2"
  }
}
